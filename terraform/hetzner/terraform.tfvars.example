# Hetzner Cloud API token (create in Cloud Console → Project → Security → API Tokens)
hcloud_token = ""

# SSH public key (content of ~/.ssh/id_ed25519.pub)
ssh_public_key = ""

# Pre-shared token for K3s cluster join (generate with: openssl rand -hex 32)
k3s_token = "CHANGE_ME"

# Name prefix for all resources
cluster_name = "photostash"

# Hetzner datacenter location (nbg1, fsn1, hel1, ash, hil)
location = "nbg1"

# Server types (cx11-cpx51, ccx13-ccx63, cax11-cax41)
server_type          = "cx23"  # k3s control plane + Traefik
database_server_type = "cx23"  # PostgreSQL + Redis
agent_server_type    = "cx23"  # Jobrunner + Webapps

# Number of webapp instances
webapp_count = 2

# PostgreSQL volume size in GB
postgres_volume_size = 50

# Restrict SSH (22) and K3s API (6443) access to specific IPs.
# Set to your own IP or VPN exit IP, e.g. ["203.0.113.42/32"]
# See docs/k3s-Hetzner-Cloudflare.md for VPN guidance.
# Default is open (matches Hetzner's default) - restrict before first apply.
admin_ips = ["0.0.0.0/0", "::/0"]
